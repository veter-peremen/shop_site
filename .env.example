# Neon PostgreSQL connection string
# Get it from your Neon project dashboard -> Connection Details
DATABASE_URL=postgresql://user:password@ep-example-12345.eu-central-1.aws.neon.tech/sonkei?sslmode=require

# Optional: public site URL, baked into the build (used for metadata/canonical links).
# For Docker: pass as --build-arg / docker-compose `args`, not a runtime env var.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: HMAC secret for the login/register captcha. If unset, a random one
# is generated per process start (captcha still works, but resets on restart).
CAPTCHA_SECRET=
